<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- App Title -->
        <TextView
            android:text="SensorRecordData"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#2C3E50"
            android:layout_marginBottom="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Accelerometer Box -->
        <LinearLayout
            android:background="#FFFFFF"
            android:padding="20dp"
            android:elevation="4dp"
            android:layout_marginBottom="16dp"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToOutline="true"
            android:radius="12dp">

            <TextView
                android:text="⚡ Accelerometer"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#4A90E2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="#E0E0E0" />

            <TextView
                android:id="@+id/accelData"
                android:text="X: 0 Y: 0 Z: 0"
                android:textSize="16sp"
                android:textColor="#555555"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Light Sensor Box -->
        <LinearLayout
            android:background="#FFFFFF"
            android:padding="20dp"
            android:elevation="4dp"
            android:layout_marginBottom="16dp"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToOutline="true"
            android:radius="12dp">

            <TextView
                android:text="💡 Light Sensor"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#F5C242"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="#E0E0E0" />

            <TextView
                android:id="@+id/lightData"
                android:text="Light: 0"
                android:textSize="16sp"
                android:textColor="#555555"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Proximity Sensor Box -->
        <LinearLayout
            android:background="#FFFFFF"
            android:padding="20dp"
            android:elevation="4dp"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToOutline="true"
            android:radius="12dp">

            <TextView
                android:text="📏 Proximity Sensor"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#26A69A"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="#E0E0E0" />

            <TextView
                android:id="@+id/proximityData"
                android:text="Proximity: 0"
                android:textSize="16sp"
                android:textColor="#555555"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>

</ScrollView>