<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TITLE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Media Player"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#222222"
            android:layout_marginBottom="20dp"/>

        <!-- VIDEO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎥 Video Player"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#1565C0"
            android:layout_marginBottom="8dp"/>

        <VideoView
            android:id="@+id/videoView"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="#000000"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/urlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Paste video URL"
            android:padding="12dp"
            android:background="#FFFFFF"
            android:textColor="#222222"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/openUrlBtn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="🌐 Open URL"
            android:textSize="14sp"
            android:backgroundTint="#64B5F6"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="10dp"/>

        <!-- Video Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp"
            android:weightSum="4">

            <Button
                android:id="@+id/playVideoBtn"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="▶ Play"
                android:textSize="14sp"
                android:backgroundTint="#90CAF9"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/pauseVideoBtn"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="⏸ Pause"
                android:textSize="14sp"
                android:backgroundTint="#64B5F6"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/stopVideoBtn"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="⏹ Stop"
                android:textSize="14sp"
                android:backgroundTint="#90CAF9"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/restartVideoBtn"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="🔁 Restart"
                android:textSize="14sp"
                android:backgroundTint="#64B5F6"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <!-- AUDIO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎧 Audio Player"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#00695C"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/openAudioBtn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="📂 Open Audio"
            android:textSize="14sp"
            android:backgroundTint="#4DB6AC"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="10dp"/>

        <!-- Audio Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4">

            <Button
                android:id="@+id/playAudioBtn"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="▶ Play"
                android:textSize="14sp"
                android:backgroundTint="#80CBC4"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/pauseAudioBtn"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="⏸ Pause"
                android:textSize="14sp"
                android:backgroundTint="#4DB6AC"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/stopAudioBtn"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="⏹ Stop"
                android:textSize="14sp"
                android:backgroundTint="#80CBC4"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/restartAudioBtn"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="🔁 Restart"
                android:textSize="14sp"
                android:backgroundTint="#4DB6AC"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>